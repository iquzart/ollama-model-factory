# 9B model but tuned for speed
FROM qwen3.5:9b-q4_K_M

# --- Speed & Determinism ---
PARAMETER temperature 0.1
PARAMETER top_k 20
PARAMETER top_p 0.85
PARAMETER repeat_penalty 1.1

# --- Memory & Context Management ---
# 4096 is the "sweet spot" for M3 bandwidth without hitting swap
PARAMETER num_ctx 4096
PARAMETER num_predict 256

# --- Apple Silicon Hardware Tuning ---
# IMPORTANT: Setting num_gpu to -1 tells Ollama to offload EVERYTHING to Metal
PARAMETER num_gpu -1

# For M3, matching thread count to Performance cores (usually 5 or 6) is best. 
# Avoid using all 11 threads to prevent background system lag.
PARAMETER num_thread 6

# --- System Prompt ---
SYSTEM """
Be precise, short, and factual. No hallucinations. No unnecessary explanations.
"""
